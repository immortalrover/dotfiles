" ==================== Editor behavior ====================
let &t_ut=''
" set number
" set cursorline
set noexpandtab
set tabstop=4
set shiftwidth=4
set softtabstop=4
set scrolloff=4
set ignorecase
set smartcase
set virtualedit=block

" =================== Keyboard layout =====================
" if you want to use Colemak layout, please delete the " at the beginning
" source ~/.vim/colemak.vim

call plug#begin('~/.vim/plugged')
call plug#end()
